# ===== BACKEND ENVIRONMENT VARIABLES =====
# Copie este arquivo para .env no Vercel console

# MongoDB Atlas Connection String
# Formato: mongodb+srv://username:password@cluster.mongodb.net/belahub?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@belahub-cluster.mongodb.net/belahub?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=seu_secret_aleatorio_super_seguro_min_32_caracteres_aqui
JWT_EXPIRY=7d

# Node Environment
NODE_ENV=production

# ===== FRONTEND ENVIRONMENT VARIABLES =====
# Para o React frontend (arquivo frontend/.env.production)
REACT_APP_API_URL=https://api.belahub.com.br
REACT_APP_JWT_STORAGE_KEY=belahub_jwt_token
REACT_APP_USUARIO_STORAGE_KEY=belahub_usuario

# ===== SEGURANÇA =====
# Estas variáveis devem ser GERADAS e protegidas no Vercel console
# Nunca commitar secrets no repositório!

# CORS - Domínios permitidos (separados por comma)
ALLOWED_ORIGINS=https://belahub.com.br,https://www.belahub.com.br

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== STRIPE (Futuro) =====
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...

# ===== VERIFICAÇÃO DE CHECKLIST =====
# [ ] MONGODB_URI - Criar cluster MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
# [ ] JWT_SECRET - Gerar string aleatória segura (64+ caracteres)
# [ ] NODE_ENV - Manter como "production"
# [ ] Adicionar todas as vars no Vercel Console (Settings > Environment Variables)
# [ ] Redeployed após adicionar vars
# [ ] Testar API com: curl -H "Authorization: Bearer TOKEN" https://api.belahub.com.br/api/funcionarios
